APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8005
FRONTEND_ORIGIN=http://127.0.0.1:4173
DATABASE_URL=sqlite:///./backend/data/macro_dashboard.db
DEMO_MODE=true
SCHEDULER_ENABLED=true
BOOTSTRAP_ON_STARTUP=true
REFRESH_HOUR=6
REFRESH_MINUTE=0
ENABLE_ALERTS=true
REGIME_CONFIG_PATH=backend/config/regime_config.json
FRED_API_KEY=
EIA_API_KEY=
MARKET_DATA_API_KEY=
AISHUB_USERNAME=

# Additional local frontend origins already supported in code:
# http://127.0.0.1:4173
# http://127.0.0.1:5174

# For DigitalOcean App Platform, DATABASE_URL should be supplied by managed Postgres.
# Example format if you set it manually:
# DATABASE_URL=postgresql://username:password@host:25060/defaultdb?sslmode=require
